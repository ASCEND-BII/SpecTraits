Package: SpecTraits
Title: A Shiny Application for Prediction and Modeling of Leaf Traits from Reflectance
Version: 0.1.0
Authors@R: c(person(given = "J. Antonio",
                    family = "Guzmán Q.",
                    role = c("cre", "aut", "cph"),
                    email = "antguz06@gmail.com",
